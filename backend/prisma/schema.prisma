generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums

enum Role {
  user
  admin
}

enum AuditEvent {
  register
  login_success
  login_failure
  logout
  token_rotated
  refresh_reuse_detected
  email_verified
  role_changed
}

enum ListingStatus {
  draft
  active
  sold
}

enum PriceChangeReason {
  created
  asking_price_change
  revaluation
}

// User

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(user)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  auditLogs               AuditLog[]
  listings                Listing[]
  favorites               Favorite[]
  searchHistory           SearchHistory[]

  @@index([email])
}

// Listing
//
// A marketplace vehicle listing. The first 13 columns (manufacturer..state)
// are the exact spec fields the model-service /predict endpoint consumes —
// keeping them 1-to-1 means valuation-on-write is a straight field map.
// predicted* + dealDeltaPct are derived (written by the service on create and
// on any spec/price change), never supplied by the client.

model Listing {
  id           String        @id @default(cuid())

  // ── Spec fields (1:1 with model-service /predict input) ──
  manufacturer String
  model        String
  year         Int
  odometer     Int
  cylinders    Int? // optional — model-service defaults to the dataset median
  condition    String
  fuel         String
  titleStatus  String
  transmission String
  drive        String
  type         String
  paintColor   String
  state        String

  // ── Marketplace fields ──
  askingPrice  Int
  description  String?
  contactEmail String
  contactPhone String?
  status       ListingStatus @default(draft)

  // ── Derived valuation (written by the service, never the client) ──
  predictedValue Int?
  predictedLow   Int?
  predictedHigh  Int?
  // (asking - predicted) / predicted * 100. Negative = below market (good deal).
  dealDeltaPct   Float?

  // ── Ownership / audit ──
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  priceHistory ListingPriceHistory[]
  favorites    Favorite[]

  @@index([userId])
  @@index([status])
  @@index([manufacturer])
}

// ListingPriceHistory
//
// Append-only audit trail: one row every time a listing's askingPrice or its
// valuation (predictedValue/Low/High) changes — including the initial create. Written
// transactionally alongside the Listing so a price and its audit row never
// drift apart.

// Favorite
//
// A user's saved listing. The unique constraint prevents double-saving.
// Both cascades ensure rows are cleaned up automatically when either side
// is deleted — no explicit cleanup needed in application code.

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
}

// SearchHistory
//
// One row per browse call made by an authenticated user. userId is nullable
// (SetNull on user delete) so the row survives account deletion while still
// preserving the aggregate signal. Guest browse calls are not recorded —
// collecting anonymous data has no recommendation value and adds privacy risk.

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String?
  filters   Json
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model ListingPriceHistory {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  oldAskingPrice    Int? // null on the initial `created` row
  newAskingPrice    Int
  oldPredictedValue Int?
  newPredictedValue Int?
  oldPredictedLow   Int?
  newPredictedLow   Int?
  oldPredictedHigh  Int?
  newPredictedHigh  Int?

  reason    PriceChangeReason
  changedAt DateTime          @default(now())

  @@index([listingId])
  @@index([changedAt])
}

// RefreshToken

model RefreshToken {
  // tokenHash stores the SHA-256 of the raw token — nunca el token como tal
  // familyId groups the token chain for a single login session so the whole
  // family can be revoked when a reuse-attack is detected
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  familyId   String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([tokenHash])
}

// EmailVerificationToken

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

// AuditLog
// Append-only event store for auth events. userId is NULLABLE so that events
// with no associated user (e.g. login_failure for unknown email) can be stored,
// and so rows survive user deletion (onDelete: SetNull, not Cascade).

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  event     AuditEvent
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([event])
  @@index([createdAt])
  @@map("auth_audit_log")
}
