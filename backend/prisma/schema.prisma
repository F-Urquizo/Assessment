generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums

enum Role {
  user
  admin
}

enum ListingStatus {
  draft
  active
  sold
}

// User

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(user)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens          RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  listings               Listing[]

  @@index([email])
}

// Listing
//
// A marketplace vehicle listing. The first 13 columns (manufacturer..state)
// are the exact spec fields the model-service /predict endpoint consumes —
// keeping them 1-to-1 means valuation-on-write is a straight field map.
// predicted* + dealDeltaPct are derived (written by the service on create and
// on any spec/price change), never supplied by the client.

model Listing {
  id           String        @id @default(cuid())

  // ── Spec fields (1:1 with model-service /predict input) ──
  manufacturer String
  model        String
  year         Int
  odometer     Int
  cylinders    Int? // optional — model-service defaults to the dataset median
  condition    String
  fuel         String
  titleStatus  String
  transmission String
  drive        String
  type         String
  paintColor   String
  state        String

  // ── Marketplace fields ──
  askingPrice  Int
  description  String?
  contactEmail String
  contactPhone String?
  status       ListingStatus @default(draft)

  // ── Derived valuation (written by the service, never the client) ──
  predictedValue Int?
  predictedLow   Int?
  predictedHigh  Int?
  // (asking - predicted) / predicted * 100. Negative = below market (good deal).
  dealDeltaPct   Float?

  // ── Ownership / audit ──
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([manufacturer])
}

// RefreshToken

model RefreshToken {
  // tokenHash stores the SHA-256 of the raw token — nunca el token como tal
  // familyId groups the token chain for a single login session so the whole
  // family can be revoked when a reuse-attack is detected
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  familyId   String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([tokenHash])
}

// EmailVerificationToken

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}
