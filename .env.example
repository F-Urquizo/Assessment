# ── Postgres credentials ─────────────────────────────────────────────────────
# Used by docker-compose for the postgres service AND interpolated into the
# backend's DATABASE_URL override inside the container.
POSTGRES_USER=appuser
POSTGRES_PASSWORD=secret
POSTGRES_DB=appraisal

# ── Database URL ─────────────────────────────────────────────────────────────
# Used by Prisma CLI running on the HOST (migrations, studio, status checks).
# Points to localhost because the host talks to the published 5432 port.
# Inside the container, docker-compose overrides this to postgres:5432.
DATABASE_URL=postgresql://appuser:secret@localhost:5432/appraisal?schema=public
# Production: append ?sslmode=require for encrypted connections to the DB.
# Example: postgresql://user:pass@db.example.com:5432/appraisal?schema=public&sslmode=require

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_at_least_32_chars_access
JWT_REFRESH_SECRET=change_me_at_least_32_chars_refresh

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=change_me_smtp_password
SMTP_FROM=noreply@example.com

# ── Model service ─────────────────────────────────────────────────────────────
# When NestJS runs on the host (npm run start:dev) it reaches Flask directly.
# Inside compose this is overridden to http://model-service:5050.
MODEL_SERVICE_URL=http://127.0.0.1:5050

# ── NestJS ───────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
# Base URL used to build the verify-email link sent to the user.
FRONTEND_URL=http://localhost:5173

# ── Cookie topology ──────────────────────────────────────────────────────────
# Same domain → lax / false. Cross-domain (Vercel+Render) → none / true.
# IMPORTANT: COOKIE_SECURE must be false over plain HTTP or the browser drops
# the cookie and login/refresh break silently.
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# ── TLS ──────────────────────────────────────────────────────────────────────
# Default: no TLS_MODE → plain HTTP on :3000, no HSTS.
# For Docker/CI leave TLS_MODE unset; the ingress or cloud LB handles TLS.
#
# TLS_MODE=direct  → NestJS creates the HTTPS server (cert required, see README § TLS)
# TLS_MODE=proxy   → NestJS runs HTTP behind a TLS-terminating ingress
#
# Uncomment for TLS_MODE=direct opt-in (local HTTPS demo):
# TLS_MODE=direct
# TLS_KEY_PATH=certs/server.key
# TLS_CERT_PATH=certs/server.crt
# PORT=3443
# HTTP_REDIRECT_PORT=3080
# COOKIE_SECURE=true

# ── HSTS (only emitted when TLS_MODE=direct or proxy) ────────────────────────
# preload=false until the production domain is confirmed — preloading is
# irreversible for ≥1 year and applies to ALL subdomains.
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUB_DOMAINS=true
HSTS_PRELOAD=false

# ── Encryption at rest ───────────────────────────────────────────────────────
# 64-char hex string = 32-byte AES-256 key.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
